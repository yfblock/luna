@@ -136,6 +136,19 @@ struct lkl_host_operations {
 	void (*print)(const char *str, int len);
 	void (*panic)(void);
 
+	/**
+	 * console_start - 启动 host 侧的虚拟串口输入轮询。host 应开一个独立线程
+	 * 轮询输入源（seL4 上为 COM1），把字符放进一个 SPSC 环，并在环从空变非空时
+	 * 调用 lkl_trigger_irq(@irq) 注入 IRQ。可在任意 host 线程调用 lkl_trigger_irq。
+	 * @irq 由 LKL 分配并通过此参数告知 host。
+	 */
+	void (*console_start)(int irq);
+	/**
+	 * console_take - 在 LKL IRQ 上下文中从环里取一个字符（非阻塞）。
+	 * @return 0..255 的字符，或 -1 表示环空。
+	 */
+	int (*console_take)(void);
+
 	struct lkl_sem* (*sem_alloc)(int count);
 	void (*sem_free)(struct lkl_sem *sem);
 	void (*sem_up)(struct lkl_sem *sem);
