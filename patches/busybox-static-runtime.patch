+static int
+luna_static_argv(union node *cmd, char ***argv_out)
+{
+	struct arglist arglist;
+	struct strlist *sp;
+	union node *argp;
+	char **argv;
+	int argc = 0;
+	int index = 0;
+
+	if (!cmd || cmd->type != NCMD || cmd->ncmd.assign || cmd->ncmd.redirect)
+		return -1;
+	arglist.list = NULL;
+	arglist.lastp = &arglist.list;
+	for (argp = cmd->ncmd.args; argp; argp = argp->narg.next)
+		expandarg(argp, &arglist, EXP_FULL | EXP_TILDE);
+	for (sp = arglist.list; sp; sp = sp->next)
+		argc++;
+	if (!argc)
+		return -1;
+	argv = stalloc(sizeof(char *) * (argc + 1));
+	for (sp = arglist.list; sp; sp = sp->next)
+		argv[index++] = sp->text;
+	argv[index] = NULL;
+	*argv_out = argv;
+	return 0;
+}
+
+static int
+luna_static_pipeline(union node *pipeline)
+{
+	struct nodelist *stage;
+	char ***commands;
+	int count = 0;
+	int index = 0;
+	for (stage = pipeline->npipe.cmdlist; stage; stage = stage->next)
+		count++;
+	if (pipeline->npipe.pipe_backgnd || count < 2 || count > 4)
+		return -1;
+	commands = stalloc(sizeof(char **) * count);
+	for (stage = pipeline->npipe.cmdlist; stage; stage = stage->next) {
+		if (luna_static_argv(stage->n, &commands[index]))
+			return -1;
+		index++;
+	}
+	return luna_bb_run_pipeline(count, commands);
+}
